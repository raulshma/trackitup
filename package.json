{
  "name": "trackitup",
  "main": "expo-router/entry",
  "version": "0.0.5",
  "scripts": {
    "start": "bun expo start",
    "android": "cross-env APP_VARIANT=development bun expo run:android",
    "android:start": "cross-env APP_VARIANT=development bun expo start --android",
    "ios": "bun expo run:ios",
    "web": "bun expo start --web",
    "clean:prebuild": "cross-env APP_VARIANT=development npx expo prebuild --clean --platform android",
    "build:apk": "cross-env APP_VARIANT=production node ./scripts/build-android-apk.mjs",
    "test": "node --test tests/*.test.mjs",
    "test:workspace-tools": "node --test tests/workspaceTools.test.mjs",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.19.30",
    "@nozbe/watermelondb": "^0.28.0",
    "@openrouter/ai-sdk-provider": "^2.2.5",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "^8.4.1",
    "@react-navigation/native": "^7.1.28",
    "ai": "^6.0.116",
    "expo": "~55.0.5",
    "expo-auth-session": "~55.0.7",
    "expo-blur": "~55.0.9",
    "expo-camera": "~55.0.9",
    "expo-constants": "~55.0.7",
    "expo-crypto": "~55.0.9",
    "expo-file-system": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.7",
    "expo-local-authentication": "~55.0.8",
    "expo-location": "~55.1.2",
    "expo-notifications": "~55.0.11",
    "expo-print": "~55.0.8",
    "expo-router": "~55.0.4",
    "expo-secure-store": "~55.0.8",
    "expo-speech-recognition": "^3.1.1",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "immer": "^11.1.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-bootsplash": "^7.1.0",
    "react-native-paper": "^5.15.0",
    "react-native-reanimated": "^4.2.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.3",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "cross-env": "^10.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
